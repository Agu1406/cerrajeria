---
import { siteConfig } from '../config/site';
---

<a
  href={siteConfig.telefonoHref}
  class="fixed bottom-4 right-4 z-50 inline-flex items-center gap-2 rounded-full bg-emerald-500 px-4 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/40 transition hover:bg-emerald-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-300 sm:hidden"
  aria-label={`Llamar ahora a ${siteConfig.nombreComercial}`}
>
  <span>📞 Llamar 24h</span>
</a>

