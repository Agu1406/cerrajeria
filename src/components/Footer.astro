---
import { siteConfig } from '../config/site';

const showDesarrollador = siteConfig.desarrollador?.nombre;
---

<footer class="border-t border-slate-800 bg-slate-950/90">
  <div class="mx-auto flex max-w-5xl flex-col gap-2 px-4 py-6 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
    <p>
      © {new Date().getFullYear()} {siteConfig.nombreComercial}. Cerrajería 24h en {siteConfig.ciudadPrincipal}.
    </p>
    <div class="flex flex-col gap-1 text-xs text-slate-400 sm:items-end sm:text-right">
      <p>
        Teléfono urgente:
        <a href={siteConfig.telefonoHref} class="font-semibold text-emerald-400 hover:underline">
          {siteConfig.telefono}
        </a>
      </p>
      <nav class="flex flex-wrap gap-3 text-[11px]">
        <a href="/aviso-legal" class="hover:text-emerald-300">
          Aviso legal
        </a>
        <a href="/politica-privacidad" class="hover:text-emerald-300">
          Privacidad
        </a>
        <a href="/politica-cookies" class="hover:text-emerald-300">
          Cookies
        </a>
        {showDesarrollador && (
          <a href="/diseno-web" class="hover:text-emerald-300">
            Diseño web
          </a>
        )}
      </nav>
    </div>
  </div>
</footer>

