---
import { siteConfig } from '../config/site';

const showDesarrollador = siteConfig.desarrollador?.nombre;
const direccion = siteConfig.direccion;
const mapsHref = siteConfig.googleMapsUrl
  ? siteConfig.googleMapsUrl
  : direccion
    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${direccion.calle}, ${direccion.codigoPostal} ${direccion.localidad}`)}`
    : '';
---

<footer class="border-t border-slate-800 bg-slate-950/90">
  <div class="mx-auto flex max-w-5xl flex-col gap-2 px-4 py-6 text-xs text-slate-400 sm:flex-row sm:items-center sm:justify-between">
    <p>
      © {new Date().getFullYear()} {siteConfig.nombreComercial}. Cerrajería 24h en {siteConfig.ciudadPrincipal}.
    </p>
    <div class="flex flex-col gap-1 text-xs text-slate-400 sm:items-end sm:text-right">
      <p>
        Teléfono urgente:
        <a href={siteConfig.telefonoHref} class="inline-block min-h-[44px] min-w-[44px] py-2 font-semibold text-emerald-400 underline decoration-emerald-400/50 hover:decoration-emerald-400" aria-label={`Llamar al ${siteConfig.telefono}`}>
          {siteConfig.telefono}
        </a>
      </p>
      <nav class="flex flex-wrap gap-1 text-[11px]" aria-label="Enlaces legales y de interés">
        {mapsHref && (
          <a href={mapsHref} target="_blank" rel="noopener noreferrer" class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center py-2 px-1 -my-1 -mx-1 hover:text-emerald-300">
            Cómo llegar
          </a>
        )}
        <a href="/blog" class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center py-2 px-1 -my-1 -mx-1 hover:text-emerald-300">
          Blog
        </a>
        <a href="/aviso-legal" class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center py-2 px-1 -my-1 -mx-1 hover:text-emerald-300">
          Aviso legal
        </a>
        <a href="/politica-privacidad" class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center py-2 px-1 -my-1 -mx-1 hover:text-emerald-300">
          Privacidad
        </a>
        <a href="/politica-cookies" class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center py-2 px-1 -my-1 -mx-1 hover:text-emerald-300">
          Cookies
        </a>
        {showDesarrollador && (
          <a href="/diseno-web" class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center py-2 px-1 -my-1 -mx-1 hover:text-emerald-300">
            Diseño web
          </a>
        )}
      </nav>
    </div>
  </div>
</footer>

