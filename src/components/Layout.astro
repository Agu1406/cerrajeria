---
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import CallButton from './CallButton.astro';
import { siteConfig } from '../config/site';

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
};

const {
  title = siteConfig.titleHome,
  description = siteConfig.descriptionHome,
  noindex = false,
} = Astro.props as Props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="AKnVTlD2lp-EazjmFzbUqWu6RMPwILePS_sjqNB-dTY" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {siteConfig.baseUrl !== 'https://TU-DOMINIO-AQUI' && (
      <>
        <link rel="canonical" href={`${siteConfig.baseUrl}${Astro.url.pathname}`} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={`${siteConfig.baseUrl}${Astro.url.pathname}`} />
        <meta property="og:type" content="website" />
        <meta
          property="og:image"
          content={`${siteConfig.baseUrl}/images/cerrajero-24h-madrid-hero.png`}
        />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta
          name="twitter:image"
          content={`${siteConfig.baseUrl}/images/cerrajero-24h-madrid-hero.png`}
        />
      </>
    )}
    <title>{title}</title>
    {siteConfig.baseUrl !== 'https://TU-DOMINIO-AQUI' && (
      <script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "cerrajerosmadrid",
  "url": "https://loscerrajerosmadrid.es",
  "telephone": "659 81 05 70",
  "areaServed": {
    "@type": "AdministrativeArea",
    "name": "Comunidad de Madrid"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Getafe",
    "addressRegion": "Madrid",
    "addressCountry": "ES",
    "streetAddress": "Calle Progreso 2, Puerta 2, Oficina 825",
    "postalCode": "28906"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": [
        "Monday",
        "Tuesday",
        "Wednesday",
        "Thursday",
        "Friday",
        "Saturday",
        "Sunday"
      ],
      "opens": "00:00",
      "closes": "23:59"
    }
  ],
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates",
      "latitude": 40.4168,
      "longitude": -3.7038
    },
    "geoRadius": 50000
  }
}
      </script>
    )}
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored;
          if (!stored) {
            var hour = new Date().getHours();
            theme = (hour >= 7 && hour < 19) ? 'light' : 'dark';
            localStorage.setItem('theme', theme);
          }
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <script is:inline>
      (function() {
        try {
          document.documentElement.dataset.cookieConsent = localStorage.getItem('cookie-consent') ? 'given' : 'pending';
        } catch (e) {
          document.documentElement.dataset.cookieConsent = 'pending';
        }
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <Header />
    <main class="mx-auto max-w-5xl px-4 py-10 sm:py-14">
      <slot />
    </main>
    <Footer />
    <CallButton />
    <div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Aviso de cookies" aria-live="polite">
      <p class="cookie-banner-text">
        Usamos cookies técnicas necesarias para el funcionamiento de la web. Si continúas navegando, aceptas su uso.
        <a href="/politica-cookies" class="underline hover:no-underline">Más información</a>.
      </p>
      <button type="button" id="cookie-banner-accept" class="cookie-banner-btn">
        Aceptar
      </button>
    </div>
    <script is:inline>
      (function() {
        var banner = document.getElementById('cookie-banner');
        var btn = document.getElementById('cookie-banner-accept');
        var root = document.documentElement;
        function hideBanner() {
          try { localStorage.setItem('cookie-consent', 'accepted'); } catch (e) {}
          root.dataset.cookieConsent = 'given';
          if (banner) banner.classList.add('cookie-banner--hidden');
        }
        if (btn) btn.addEventListener('click', hideBanner);
        if (root.dataset.cookieConsent === 'given' && banner) banner.classList.add('cookie-banner--hidden');
      })();
    </script>
  </body>
</html>

