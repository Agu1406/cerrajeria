---
import '../styles/global.css';
import Header from './Header.astro';
import Footer from './Footer.astro';
import CallButton from './CallButton.astro';
import { siteConfig } from '../config/site';

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
  /** URL completa de la imagen para redes (og:image). Si no se pasa, se usa la imagen por defecto. */
  ogImage?: string;
  /** Breadcrumb para schema (ej. [{ name: 'Inicio', path: '/' }, { name: 'Cerrajero 24h', path: '/cerrajero-urgente-24h' }, { name: 'Las Rozas', path: '/cerrajero-urgente-24h/las-rozas' }]). */
  breadcrumb?: Array<{ name: string; path: string }>;
};

const {
  title = siteConfig.titleHome,
  description = siteConfig.descriptionHome,
  noindex = false,
  ogImage,
  breadcrumb,
} = Astro.props as Props;

const defaultOgImage = `${siteConfig.baseUrl}/images/cerrajero-24h-madrid-hero.webp`;
const imageForSocial = ogImage ?? defaultOgImage;

const reseñas = siteConfig.reseñas;
const direccion = siteConfig.direccion;
const schemaLocalBusiness: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: siteConfig.nombreComercial,
  url: siteConfig.baseUrl,
  telephone: siteConfig.telefono,
  ...(siteConfig.email && { email: siteConfig.email }),
  areaServed: { '@type': 'AdministrativeArea', name: 'Comunidad de Madrid' },
  ...(direccion && {
    address: {
      '@type': 'PostalAddress',
      addressLocality: direccion.localidad,
      addressRegion: siteConfig.ciudadPrincipal,
      addressCountry: 'ES',
      streetAddress: direccion.calle,
      postalCode: direccion.codigoPostal,
    },
  }),
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: '00:00',
    closes: '23:59',
  }],
  serviceArea: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: 40.4168, longitude: -3.7038 },
    geoRadius: 50000,
  },
};
if (reseñas && reseñas.totalResenas > 0) {
  schemaLocalBusiness.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: reseñas.valoracionMedia,
    bestRating: 5,
    worstRating: 1,
    reviewCount: reseñas.totalResenas,
  };
  if (reseñas.reseñas?.length) {
    schemaLocalBusiness.review = reseñas.reseñas.slice(0, 5).map((r) => ({
      '@type': 'Review',
      author: { '@type': 'Person', name: r.autor },
      reviewRating: { '@type': 'Rating', ratingValue: r.valoracion, bestRating: 5 },
      reviewBody: r.texto,
      datePublished: r.fecha,
    }));
  }
}

const pageUrl = `${siteConfig.baseUrl.replace(/\/$/, '')}${Astro.url.pathname}`;
const whatsappHref = siteConfig.whatsappMessage
  ? `${siteConfig.whatsappUrl}?text=${encodeURIComponent(
      siteConfig.whatsappMessage + ' Escribo desde: ' + pageUrl
    )}`
  : siteConfig.whatsappUrl;
---

<html lang="es" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="AKnVTlD2lp-EazjmFzbUqWu6RMPwILePS_sjqNB-dTY" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {siteConfig.baseUrl !== 'https://TU-DOMINIO-AQUI' && (
      <>
        <link rel="canonical" href={`${siteConfig.baseUrl}${Astro.url.pathname}`} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={`${siteConfig.baseUrl}${Astro.url.pathname}`} />
        <meta property="og:type" content="website" />
        <meta property="og:image" content={imageForSocial} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={imageForSocial} />
      </>
    )}
    <title>{title}</title>
    {siteConfig.baseUrl !== 'https://TU-DOMINIO-AQUI' && (
      <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
    )}
    {siteConfig.baseUrl !== 'https://TU-DOMINIO-AQUI' && breadcrumb && breadcrumb.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumb.map((item, i) => ({
          '@type': 'ListItem',
          position: i + 1,
          name: item.name,
          item: `${siteConfig.baseUrl}${item.path}`,
        })),
      })} />
    )}
    <script is:inline>
      (function() {
        try {
          document.documentElement.dataset.cookieConsent = localStorage.getItem('cookie-consent') ? 'given' : 'pending';
        } catch (e) {
          document.documentElement.dataset.cookieConsent = 'pending';
        }
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <Header whatsappHref={whatsappHref} />
    <main class="mx-auto max-w-5xl px-4 py-10 sm:py-14">
      <slot />
    </main>
    <Footer />
    <CallButton whatsappHref={whatsappHref} />
    <div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Aviso de cookies" aria-live="polite">
      <p class="cookie-banner-text">
        Usamos cookies técnicas necesarias para el funcionamiento de la web. Si continúas navegando, aceptas su uso.
        <a href="/politica-cookies" class="underline hover:no-underline">más información sobre cookies</a>.
      </p>
      <button type="button" id="cookie-banner-accept" class="cookie-banner-btn">
        Aceptar
      </button>
    </div>
    <script is:inline>
      (function() {
        var banner = document.getElementById('cookie-banner');
        var btn = document.getElementById('cookie-banner-accept');
        var root = document.documentElement;
        function hideBanner() {
          try { localStorage.setItem('cookie-consent', 'accepted'); } catch (e) {}
          root.dataset.cookieConsent = 'given';
          if (banner) banner.classList.add('cookie-banner--hidden');
        }
        if (btn) btn.addEventListener('click', hideBanner);
        if (root.dataset.cookieConsent === 'given' && banner) banner.classList.add('cookie-banner--hidden');
      })();
    </script>
  </body>
</html>

