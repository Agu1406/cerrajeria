---
import Layout from '../components/Layout.astro';
import { siteConfig } from '../config/site';

const title = `Página no encontrada | ${siteConfig.nombreComercial}`;
const description =
  'La página que buscas no existe. Llama ahora a nuestro servicio de cerrajería 24 horas en Madrid para resolver cualquier urgencia.';
---

<Layout {title} {description} noindex={true}>
  <section class="space-y-6 text-sm text-slate-300">
    <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">
      Página no encontrada
    </h1>
    <p>
      Es posible que la dirección que has escrito no exista o que el enlace esté desactualizado. Si necesitas ayuda con
      una urgencia de cerrajería en Madrid, puedes llamarnos ahora mismo.
    </p>
    <div class="flex flex-wrap items-center gap-3">
      <a
        href={siteConfig.telefonoHref}
        class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/40 transition hover:bg-emerald-400 active:scale-95"
      >
        📞 Llamar ahora · {siteConfig.telefono}
      </a>
      <a
        href="/"
        class="text-xs font-semibold text-emerald-400 underline-offset-4 hover:underline"
      >
        Volver al inicio
      </a>
    </div>
  </section>
</Layout>

