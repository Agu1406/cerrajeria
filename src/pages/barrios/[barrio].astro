---
import Layout from '../../components/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { siteConfig } from '../../config/site';
import { servicios } from '../../data/servicios';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('barrios');
  return entries.map((entry) => ({
    params: { barrio: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'barrios'>;
};

const { entry } = Astro.props as Props;
const data = entry.data;

const allBlogPosts = await getCollection('blog', ({ data: d }) => !d.draft);
const latestPosts = allBlogPosts
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const title = `Cerrajero 24h en ${data.nombre} | ${siteConfig.nombreComercial}`;
const description = `Cerrajero urgente 24 horas en ${data.nombre} (${siteConfig.ciudadPrincipal}). Apertura de puertas sin daños, cambios de bombín y asistencia rápida. Llama al ${siteConfig.telefono}.`;
---

<Layout {title} {description}>
  <section class="space-y-6">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">
      Urgencias 24h · {data.nombre}
    </p>
    <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
      Cerrajeros 24 horas en {data.nombre}
    </h1>
    <p class="text-sm text-slate-300 sm:text-base">
      Servicio de cerrajería urgente en {data.nombre} y alrededores. Apertura de puertas sin daños, cambio de
      cerraduras y refuerzo de seguridad en viviendas, locales y comunidades de vecinos.
    </p>
    <p class="text-sm text-slate-300 sm:text-base">
      {data.introExtra}
    </p>

    <div class="flex flex-wrap items-center gap-3">
      <a
        href={siteConfig.telefonoHref}
        class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/40 transition hover:bg-emerald-400"
      >
        📞 Llamar ahora · {siteConfig.telefono}
      </a>
      <p class="text-xs text-slate-400">
        {data.llegadaTexto}
      </p>
    </div>

    <section class="mt-6 grid gap-4 md:grid-cols-3">
      <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4 text-sm">
        <h2 class="mb-2 text-sm font-semibold">Urgencias sin daños</h2>
        <p class="text-slate-300">
          Apertura de puertas blindadas y acorazadas sin romper la cerradura siempre que sea posible. Explicamos
          el trabajo antes de empezar.
        </p>
      </div>
      <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4 text-sm">
        <h2 class="mb-2 text-sm font-semibold">Cambio e instalación de cerraduras</h2>
        <p class="text-slate-300">
          Cambiamos e instalamos cerraduras y bombines de alta seguridad, con opciones antibumping y antitaladro
          para viviendas y locales en {data.nombre}.
        </p>
      </div>
      <div class="rounded-xl border border-slate-800 bg-slate-900/70 p-4 text-sm">
        <h2 class="mb-2 text-sm font-semibold">Ventanas y herrajes</h2>
        <p class="text-slate-300">
          Arreglo de ventanas oscilobatientes y osciloparalelas, así como ajuste de herrajes y cierres que no
          encajan bien.
        </p>
      </div>
    </section>

    <section class="mt-8 space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Servicios habituales de cerrajería en {data.nombre}
      </h2>
      <p class="text-xs text-slate-400 sm:text-sm">
        Trabajamos a diario con aperturas urgentes, cambios de cerradura y arreglos de ventanas. Estos son algunos
        de los servicios más demandados:
      </p>
      <ul class="grid gap-2 text-xs sm:text-sm">
        {servicios.slice(0, 5).map((servicio) => (
          <li>• {servicio.nombre}</li>
        ))}
      </ul>
      <p class="text-xs text-slate-400">
        Si necesitas un trabajo de cerrajería diferente en {data.nombre}, llámanos y te diremos al momento si
        podemos ayudarte.
      </p>
    </section>

    <section class="mt-8 space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Cómo trabajamos en {data.nombre}
      </h2>
      <p class="text-xs text-slate-400 sm:text-sm">
        {data.comoTrabajamos}
      </p>
    </section>

    <section class="mt-8 space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Preguntas frecuentes sobre cerrajería urgente en {data.nombre}
      </h2>
      <div class="space-y-2 text-xs text-slate-300 sm:text-sm">
        <p>
          <strong>¿Cuánto tardáis en llegar a {data.nombre}?</strong> {data.faqLlegada}
        </p>
        <p>
          <strong>¿El precio está cerrado antes de empezar?</strong> {data.faqPrecio}
        </p>
        <p>
          <strong>¿Trabajáis también de noche y en festivos en {data.nombre}?</strong> {data.faqFestivos}
        </p>
      </div>
    </section>

    <section class="mt-8 text-xs text-slate-400 sm:text-sm">
      <p>
        Si quieres ver el detalle de todos los trabajos que realizamos como aperturas, cambios de cerradura o arreglos
        de ventanas, puedes visitar la página de{' '}
        <a href="/servicios" class="text-emerald-400 hover:underline">
          servicios de cerrajería
        </a>
        .
      </p>
    </section>

    {latestPosts.length > 0 && (
      <section class="mt-10 rounded-xl border border-slate-800 bg-slate-900/40 p-4 sm:p-5">
        <h2 class="mb-3 text-sm font-semibold uppercase tracking-wider text-slate-400">
          Últimas entradas del blog
        </h2>
        <ul class="space-y-2 text-sm">
          {latestPosts.map((post) => (
            <li>
              <a
                href={`/blog/${post.slug}`}
                class="text-slate-300 hover:text-emerald-400 hover:underline"
              >
                {post.data.title}
              </a>
              <time datetime={post.data.pubDate.toISOString()} class="ml-2 text-xs text-slate-500">
                {post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}
              </time>
            </li>
          ))}
        </ul>
        <p class="mt-3 text-xs text-slate-500">
          <a href="/blog" class="text-emerald-400 hover:underline">Ver todo el blog →</a>
        </p>
      </section>
    )}

    <section class="mt-10">
      <h2 class="mb-3 text-lg font-semibold tracking-tight">
        Consulta para cerrajería en {data.nombre}
      </h2>
      <p class="mb-4 text-xs text-slate-400 sm:text-sm">
        Si no es urgente, puedes enviarnos tu consulta y te respondemos lo antes posible.
      </p>
      <ContactForm
        barrio={data.nombre}
        title="Enviar consulta (no urgente)"
        subtitle="Presupuestos, dudas o trabajos planificados en esta zona."
      />
    </section>
  </section>
</Layout>

