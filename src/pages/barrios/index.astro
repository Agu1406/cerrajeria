---
import Layout from '../../components/Layout.astro';
import { barrios } from '../../data/barrios';
import { siteConfig } from '../../config/site';

const title = `Cerrajeros por barrios en ${siteConfig.ciudadPrincipal} | ${siteConfig.nombreComercial}`;
const description =
  'Listado de barrios y zonas donde ofrecemos servicio de cerrajería urgente 24 horas en Madrid. Encuentra tu zona y llama al instante.';
---

<Layout {title} {description}>
  <section class="space-y-6">
    <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">
      Cerrajeros 24h por barrios en {siteConfig.ciudadPrincipal}
    </h1>
    <p class="text-sm text-slate-300 sm:text-base">
      Estas son las primeras zonas en las que ofrecemos servicio prioritario. Cada barrio tiene su propia página
      con información detallada y un acceso rápido a nuestro teléfono de urgencias.
    </p>

    <ul class="mt-4 grid gap-3 sm:grid-cols-2">
      {barrios.map((barrio) => (
        <li>
          <a
            href={`/barrios/${barrio.slug}`}
            class="flex flex-col rounded-lg border border-slate-800 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 transition hover:border-emerald-400 hover:text-emerald-300"
          >
            <span class="font-semibold">{barrio.nombre}</span>
            <span class="mt-1 text-xs text-slate-500">
              Cerrajero urgente 24h en {barrio.nombre}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

