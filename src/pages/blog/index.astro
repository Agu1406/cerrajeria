---
import Layout from '../../components/Layout.astro';
import { siteConfig } from '../../config/site';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const title = `Blog | ${siteConfig.nombreComercial}`;
const description = `Consejos de cerrajería, seguridad y mantenimiento de cerraduras en Madrid. ${siteConfig.descriptionHome}`;
---

<Layout {title} {description}>
  <article class="mx-auto max-w-3xl">
    <header class="mb-12 border-b border-slate-800 pb-8">
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
        Blog
      </h1>
      <p class="mt-3 text-base text-slate-400 leading-relaxed">
        Consejos de cerrajería, seguridad y mantenimiento. Publicamos contenido útil para que sepas cuándo y cómo actuar.
      </p>
    </header>

    <ul class="flex flex-col gap-8">
      {posts.map((post) => (
        <li>
          <a
            href={`/blog/${post.slug}`}
            class="group block rounded-2xl border border-slate-800 bg-slate-900/40 p-6 transition hover:border-slate-700 hover:bg-slate-900/60 sm:p-8"
          >
            <div class="flex flex-col gap-5 sm:flex-row sm:items-start sm:gap-6">
              {post.data.image ? (
                <img
                  src={post.data.image}
                  alt=""
                  class="h-44 w-full shrink-0 rounded-xl object-cover sm:h-36 sm:w-56"
                  width="224"
                  height="144"
                  loading="lazy"
                />
              ) : (
                <div class="h-44 w-full shrink-0 rounded-xl bg-slate-800/80 sm:h-36 sm:w-56" aria-hidden="true" />
              )}
              <div class="min-w-0 flex-1 space-y-2">
                <time datetime={post.data.pubDate.toISOString()} class="block text-xs font-medium uppercase tracking-wider text-slate-500">
                  {post.data.pubDate.toLocaleDateString('es-ES', {
                    day: 'numeric',
                    month: 'long',
                    year: 'numeric',
                  })}
                </time>
                <h2 class="text-xl font-semibold text-slate-100 leading-snug group-hover:text-emerald-300 sm:text-[1.25rem]">
                  {post.data.title}
                </h2>
                <p class="text-sm text-slate-400 leading-relaxed line-clamp-3">
                  {post.data.description}
                </p>
              </div>
            </div>
          </a>
        </li>
      ))}
    </ul>

    {posts.length === 0 && (
      <p class="text-sm text-slate-400 leading-relaxed">
        Próximamente publicaremos aquí consejos y novedades. Mientras tanto, <a href="/contacto" class="text-emerald-400 hover:underline">contáctanos</a> para cualquier consulta.
      </p>
    )}
  </article>
</Layout>
