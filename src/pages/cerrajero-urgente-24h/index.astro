---
import Layout from '../../components/Layout.astro';
import { siteConfig } from '../../config/site';
import { getCollection } from 'astro:content';

const title = `Cerrajero urgente 24h por barrios y distritos en Madrid | ${siteConfig.nombreComercial}`;
const description =
  'Cerrajero urgente 24 horas en los 21 distritos de Madrid capital (Centro, Salamanca, Chamberí, Vallecas, etc.) y en municipios: Getafe, Leganés, Móstoles, Fuenlabrada, Alcalá de Henares, Las Rozas, Pinto. Llama al instante.';

const barrios = (await getCollection('barrios')).sort((a, b) =>
  a.data.nombre.localeCompare(b.data.nombre, 'es')
);
---

<Layout {title} {description}>
  <section class="space-y-6">
    <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">
      Cerrajero urgente 24h por barrios y zonas en {siteConfig.ciudadPrincipal}
    </h1>
    <p class="text-sm text-slate-300 sm:text-base">
      Servicio de cerrajería urgente en los <strong>21 distritos de Madrid capital</strong> (Centro, Salamanca,
      Chamberí, Retiro, Chamartín, Tetuán, Latina, Carabanchel, Vallecas, Vicálvaro, etc.) y en <strong>municipios
      del área metropolitana</strong> (Getafe, Leganés, Móstoles, Fuenlabrada, Alcalá de Henares, Las Rozas, Pinto).
      Cada zona tiene su propia página con información y teléfono de urgencias.
    </p>

    <ul class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {barrios.map((entry) => (
        <li>
          <a
            href={`/cerrajero-urgente-24h/${entry.slug}`}
            class="flex flex-col rounded-lg border border-slate-800 bg-slate-900/80 px-4 py-3 text-sm text-slate-100 transition hover:border-emerald-400 hover:text-emerald-300"
          >
            <span class="font-semibold">{entry.data.nombre}</span>
            <span class="mt-1 text-xs text-slate-500">
              Cerrajero urgente 24h en {entry.data.nombre}
            </span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
