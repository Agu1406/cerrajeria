---
import Layout from '../components/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { siteConfig } from '../config/site';

const title = `Contacto | ${siteConfig.nombreComercial} – Cerrajeros 24h en ${siteConfig.ciudadPrincipal}`;
const description =
  `Contacta con ${siteConfig.nombreComercial} para urgencias de cerrajería 24 horas en ${siteConfig.ciudadPrincipal}. Teléfono directo, formulario de contacto y horario de atención.`;

const direccion = siteConfig.direccion;
const mapsHref = siteConfig.googleMapsUrl
  ? siteConfig.googleMapsUrl
  : direccion
    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`${direccion.calle}, ${direccion.codigoPostal} ${direccion.localidad}`)}`
    : '';
const showMapBlock = direccion || siteConfig.googleMapsUrl;
---

<Layout {title} {description}>
  <section class="grid gap-8 lg:grid-cols-[1.2fr_minmax(0,1fr)]">
    <div class="space-y-5">
      <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">
        Contacto cerrajeros 24h en {siteConfig.ciudadPrincipal}
      </h1>
      <p class="text-sm text-slate-300 sm:text-base">
        Para emergencias, la forma más rápida de hablar con nosotros es por teléfono. Si tu consulta no es urgente,
        también puedes usar el formulario y te responderemos lo antes posible.
      </p>

      <div class="space-y-2 rounded-xl border border-slate-800 bg-slate-900/70 p-4 text-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">
          Urgencias 24 horas
        </p>
        <p>
          Teléfono directo:{' '}
          <a href={siteConfig.telefonoHref} class="font-semibold text-emerald-400 hover:underline">
            {siteConfig.telefono}
          </a>
        </p>
        <p class="text-slate-400">
          Disponible todos los días del año, incluyendo noches y festivos.
        </p>
      </div>

      {showMapBlock && (
        <div class="space-y-2 rounded-xl border border-slate-800 bg-slate-900/70 p-4 text-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">
            Dónde estamos
          </p>
          {direccion && (
            <p class="text-slate-300">
              {direccion.calle}<br />
              {direccion.codigoPostal} {direccion.localidad}, {siteConfig.ciudadPrincipal}
            </p>
          )}
          {mapsHref && (
            <p>
              <a
                href={mapsHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 font-semibold text-emerald-400 hover:underline"
              >
                <span aria-hidden="true">📍</span>
                {siteConfig.googleMapsUrl ? 'Ver en Google Maps' : 'Cómo llegar (Google Maps)'}
              </a>
            </p>
          )}
        </div>
      )}
    </div>

    <aside>
      <ContactForm
        title="Formulario de contacto (no urgente)"
        subtitle="Úsalo para presupuestos, dudas sobre cerraduras o trabajos planificados."
      />
    </aside>
  </section>
</Layout>

