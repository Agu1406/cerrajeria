---
import Layout from '../../components/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { siteConfig } from '../../config/site';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('duplicado-llaves-coche-barrios');
  return entries.map((entry) => ({
    params: { barrio: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'duplicado-llaves-coche-barrios'>;
};

const { entry } = Astro.props as Props;
const data = entry.data;
const basePath = '/duplicado-llaves-coche';
const title = `Duplicado de llaves de coche en ${data.nombre} | Llaves y mandos · ${siteConfig.telefono}`;
const description = `Copia de llaves de coche y mandos en ${data.nombre} y alrededores. Llaves de reserva y sustitución. Presupuesto sin compromiso. ${siteConfig.telefono}`;
const breadcrumb = [
  { name: 'Inicio', path: '/' },
  { name: 'Servicios', path: '/servicios' },
  { name: 'Duplicado llaves de coche', path: basePath },
  { name: data.nombre, path: `${basePath}/${entry.slug}` },
];

const allBarrios = await getCollection('duplicado-llaves-coche-barrios');
const otrasZonas = allBarrios.filter((b) => b.slug !== entry.slug).slice(0, 6);

const faqSchemaDuplicadoBarrio = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    { '@type': 'Question', name: '¿Hacéis llaves de coche con chip?', acceptedAnswer: { '@type': 'Answer', text: 'Sí, para la mayoría de marcas y modelos. En la llamada te indicamos si podemos atender tu vehículo o si conviene acudir a un servicio oficial.' } },
    { '@type': 'Question', name: `¿Atienden en ${data.nombre}?`, acceptedAnswer: { '@type': 'Answer', text: `Sí, atendemos en ${data.nombre} y alrededores. Nos desplazamos a domicilio con el equipo; si tienes dudas sobre disponibilidad, llámanos y te lo confirmamos.` } },
    { '@type': 'Question', name: '¿Cuánto tarda el trabajo?', acceptedAnswer: { '@type': 'Answer', text: 'Depende del tipo de llave. Una copia mecánica puede hacerse en el acto; las llaves con chip o mandos a distancia pueden requerir más tiempo. Te lo concretamos al dar el presupuesto.' } },
  ],
  ...(entry.data.actualizado && { dateModified: entry.data.actualizado.toISOString().slice(0, 10) }),
};
const dateModified = entry.data.actualizado?.toISOString().slice(0, 10);
---

<Layout {title} {description} breadcrumb={breadcrumb} dateModified={dateModified}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchemaDuplicadoBarrio)} />
  <article class="space-y-8">
    <header class="space-y-4">
      <nav class="text-xs text-slate-400" aria-label="Miga de pan">
        <a href="/" class="hover:text-emerald-400">Inicio</a>
        <span class="mx-1">/</span>
        <a href="/servicios" class="hover:text-emerald-400">Servicios</a>
        <span class="mx-1">/</span>
        <a href={basePath} class="hover:text-emerald-400">Duplicado llaves de coche</a>
        <span class="mx-1">/</span>
        <span class="text-slate-400">{data.nombre}</span>
      </nav>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">
        Servicio a domicilio · {data.nombre}
      </p>
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
        Duplicado de llaves de coche en {data.nombre}
      </h1>
      <p class="text-sm text-slate-300 sm:text-base max-w-2xl">
        {data.intro}
      </p>
      <p class="text-sm text-slate-400">
        {data.llegadaTexto}
      </p>
      <div class="flex flex-wrap items-center gap-3 pt-2">
        <a
          href={siteConfig.telefonoHref}
          class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/40 transition hover:bg-emerald-400"
        >
          📞 Llamar · {siteConfig.telefono}
        </a>
        <p class="text-xs text-slate-400">
          Presupuesto sin compromiso en {data.nombre}.
        </p>
      </div>
    </header>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/50 p-5 sm:p-6 space-y-4">
      <h2 class="text-lg font-semibold tracking-tight">
        ¿Cuándo necesitas una copia de llave de coche en {data.nombre}?
      </h2>
      <ul class="grid gap-2 text-sm text-slate-300 sm:grid-cols-2">
        <li class="flex gap-2">
          <span class="text-emerald-400 shrink-0" aria-hidden="true">•</span>
          Llave de reserva para dejar en casa o a un familiar.
        </li>
        <li class="flex gap-2">
          <span class="text-emerald-400 shrink-0" aria-hidden="true">•</span>
          Has perdido la llave o el mando y necesitas un duplicado o sustitución.
        </li>
        <li class="flex gap-2">
          <span class="text-emerald-400 shrink-0" aria-hidden="true">•</span>
          La llave original está desgastada o el mando no responde bien.
        </li>
        <li class="flex gap-2">
          <span class="text-emerald-400 shrink-0" aria-hidden="true">•</span>
          Compraste el coche con una sola llave y quieres una copia de seguridad.
        </li>
      </ul>
    </section>

    <section class="space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Llaves con chip y mandos a distancia
      </h2>
      <p>
        Muchos coches actuales llevan llaves con transponder (chip) o mandos a distancia que requieren programación. Trabajamos con equipos adecuados para la mayoría de marcas; al llamar podemos orientarte sobre si tu modelo es viable y el tiempo aproximado. Si el vehículo es muy reciente o de gama alta, a veces hay que derivar a un especialista en tu marca; te lo indicamos con claridad.
      </p>
    </section>

    <section class="space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Precio y desplazamiento en {data.nombre}
      </h2>
      <p>
        El precio depende del tipo de llave (mecánica, con chip, mando a distancia) y de la marca del vehículo. Te damos un presupuesto orientativo por teléfono y lo cerramos al ver el coche. Nos desplazamos a {data.nombre} y alrededores; normalmente podemos atenderte el mismo día o al siguiente según disponibilidad.
      </p>
    </section>

    <section class="space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Preguntas frecuentes sobre duplicado de llaves de coche en {data.nombre}
      </h2>
      <dl class="space-y-3 text-slate-300">
        <div>
          <dt class="font-semibold text-slate-200">¿Hacéis llaves de coche con chip?</dt>
          <dd class="mt-1 text-xs sm:text-sm text-slate-400">
            Sí, para la mayoría de marcas y modelos. En la llamada te indicamos si podemos atender tu vehículo o si conviene acudir a un servicio oficial.
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-200">¿Atienden en {data.nombre}?</dt>
          <dd class="mt-1 text-xs sm:text-sm text-slate-400">
            Sí, atendemos en {data.nombre} y alrededores. Nos desplazamos a domicilio con el equipo; si tienes dudas sobre disponibilidad, llámanos y te lo confirmamos.
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-200">¿Cuánto tarda el trabajo?</dt>
          <dd class="mt-1 text-xs sm:text-sm text-slate-400">
            Depende del tipo de llave. Una copia mecánica puede hacerse en el acto; las llaves con chip o mandos a distancia pueden requerir más tiempo. Te lo concretamos al dar el presupuesto.
          </dd>
        </div>
      </dl>
      {entry.data.actualizado && (
        <p class="mt-3 text-[11px] text-slate-500">
          Contenido revisado: <time datetime={entry.data.actualizado.toISOString()}>{entry.data.actualizado.toLocaleDateString('es-ES', { month: 'long', year: 'numeric' })}</time>
        </p>
      )}
    </section>

    <section class="rounded-xl border border-slate-800 bg-slate-900/40 p-4 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight mb-2">
        Otros servicios de cerrajería
      </h2>
      <p>
        Además del duplicado de llaves de coche, realizamos apertura de puertas, cambio e instalación de cerraduras y bombines, duplicado de llaves a domicilio (vivienda, portal) y arreglo de ventanas oscilobatientes. Si necesitas un cerrajero urgente 24 horas en {data.nombre}, tenemos página específica:{' '}
        <a href={`/cerrajero-urgente-24h/${entry.slug}`} class="text-emerald-400 hover:underline">cerrajero 24h en {data.nombre}</a>. Listado completo en{' '}
        <a href="/servicios" class="text-emerald-400 hover:underline">servicios de cerrajería</a>.
      </p>
    </section>

    {otrasZonas.length > 0 && (
      <section class="space-y-3">
        <h2 class="text-base font-semibold tracking-tight">
          Duplicado de llaves de coche en otras zonas
        </h2>
        <ul class="grid gap-2 text-sm sm:grid-cols-2">
          {otrasZonas.map((other) => (
            <li>
              <a
                href={`${basePath}/${other.slug}`}
                class="text-slate-300 hover:text-emerald-400 hover:underline"
              >
                Duplicado llaves coche en {other.data.nombre}
              </a>
            </li>
          ))}
        </ul>
        <p class="text-xs text-slate-400">
          <a href={basePath} class="text-emerald-400 hover:underline">Ver duplicado de llaves de coche en Madrid →</a>
        </p>
      </section>
    )}

    <div class="flex flex-wrap items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/50 p-4">
      <p class="text-sm text-slate-300">
        ¿Necesitas presupuesto en {data.nombre}? Llámanos.
      </p>
      <a
        href={siteConfig.telefonoHref}
        class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-emerald-400"
      >
        📞 {siteConfig.telefono}
      </a>
    </div>

    <section class="mt-8">
      <ContactForm
        barrio={data.nombre}
        title={`Solicitar presupuesto en ${data.nombre}`}
        subtitle="Para duplicado de llaves de coche: indícanos marca y modelo si lo sabes. Te respondemos lo antes posible."
      />
    </section>
  </article>
</Layout>
