---
import Layout from '../../components/Layout.astro';
import { siteConfig } from '../../config/site';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('puertas-antiokupas-barrios');
  return entries.map((entry) => ({
    params: { barrio: entry.slug },
    props: { entry },
  }));
}

type Props = {
  entry: CollectionEntry<'puertas-antiokupas-barrios'>;
};

const { entry } = Astro.props as Props;
const data = entry.data;
const basePath = '/puertas-antiokupas';
const title = `Puertas antiokupas en ${data.nombre} | Refuerzo e instalación · ${siteConfig.telefono}`;
const description = `Instalación y refuerzo de puertas antiokupas en ${data.nombre} y alrededores. Viviendas y locales vacíos. Presupuesto sin compromiso. ${siteConfig.telefono}`;
const breadcrumb = [
  { name: 'Inicio', path: '/' },
  { name: 'Servicios', path: '/servicios' },
  { name: 'Puertas antiokupas', path: basePath },
  { name: data.nombre, path: `${basePath}/${entry.slug}` },
];

const allBarrios = await getCollection('puertas-antiokupas-barrios');
const otrasZonas = allBarrios.filter((b) => b.slug !== entry.slug).slice(0, 6);
---

<Layout {title} {description} breadcrumb={breadcrumb}>
  <article class="space-y-8">
    <header class="space-y-4">
      <nav class="text-xs text-slate-400" aria-label="Miga de pan">
        <a href="/" class="hover:text-emerald-400">Inicio</a>
        <span class="mx-1">/</span>
        <a href="/servicios" class="hover:text-emerald-400">Servicios</a>
        <span class="mx-1">/</span>
        <a href={basePath} class="hover:text-emerald-400">Puertas antiokupas</a>
        <span class="mx-1">/</span>
        <span class="text-slate-400">{data.nombre}</span>
      </nav>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-400">
        Refuerzo e instalación · {data.nombre}
      </p>
      <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">
        Puertas antiokupas en {data.nombre}
      </h1>
      <p class="text-sm text-slate-300 sm:text-base max-w-2xl">
        {data.intro}
      </p>
      <p class="text-sm text-slate-400">
        {data.llegadaTexto}
      </p>
      <div class="flex flex-wrap items-center gap-3 pt-2">
        <a
          href={siteConfig.telefonoHref}
          class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-6 py-3 text-sm font-semibold text-slate-950 shadow-lg shadow-emerald-500/40 transition hover:bg-emerald-400"
        >
          📞 Llamar · {siteConfig.telefono}
        </a>
        <p class="text-xs text-slate-400">
          Presupuesto sin compromiso en {data.nombre}.
        </p>
      </div>
    </header>

    <section class="rounded-2xl border border-slate-800 bg-slate-900/50 p-5 sm:p-6 space-y-4">
      <h2 class="text-lg font-semibold tracking-tight">
        ¿Cuándo instalar puertas antiokupas en {data.nombre}?
      </h2>
      <ul class="grid gap-2 text-sm text-slate-300 sm:grid-cols-2">
        <li class="flex gap-2">
          <span class="text-emerald-400 shrink-0" aria-hidden="true">•</span>
          Vivienda o local vacío que quieres proteger frente a ocupación ilegal.
        </li>
        <li class="flex gap-2">
          <span class="text-emerald-400 shrink-0" aria-hidden="true">•</span>
          Refuerzo de cerraduras y bombines para mayor resistencia.
        </li>
        <li class="flex gap-2">
          <span class="text-emerald-400 shrink-0" aria-hidden="true">•</span>
          Instalación de puertas de seguridad o blindadas en segunda vivienda.
        </li>
        <li class="flex gap-2">
          <span class="text-emerald-400 shrink-0" aria-hidden="true">•</span>
          Asesoramiento para combinar cerraduras, herrajes y disuasión visual.
        </li>
      </ul>
    </section>

    <section class="space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Refuerzo e instalación en {data.nombre}
      </h2>
      <p>
        Trabajamos con cerraduras de alta seguridad, bombines antibumping y puertas que cumplen normativa antiokupa cuando aplica. Te indicamos opciones y precios por teléfono; al visitar el inmueble en {data.nombre} concretamos la solución más adecuada al tipo de puerta y nivel de protección que busques.
      </p>
    </section>

    <section class="space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Precio y desplazamiento en {data.nombre}
      </h2>
      <p>
        El precio depende del tipo de refuerzo (solo cerradura, cambio de puerta, blindaje) y de las características del inmueble. Te damos un presupuesto orientativo por teléfono y lo cerramos en la visita. Nos desplazamos a {data.nombre} y alrededores.
      </p>
    </section>

    <section class="space-y-3 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight">
        Preguntas frecuentes sobre puertas antiokupas en {data.nombre}
      </h2>
      <dl class="space-y-3 text-slate-300">
        <div>
          <dt class="font-semibold text-slate-200">¿Qué incluye una puerta antiokupa?</dt>
          <dd class="mt-1 text-xs sm:text-sm text-slate-400">
            Depende del caso: refuerzo de cerraduras, bombines de alta seguridad, puertas blindadas o de seguridad que cumplen normativa. Te asesoramos según tu situación.
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-200">¿Atienden en {data.nombre}?</dt>
          <dd class="mt-1 text-xs sm:text-sm text-slate-400">
            Sí, atendemos en {data.nombre} y alrededores. Si tienes dudas sobre disponibilidad, llámanos y te lo confirmamos.
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-slate-200">¿Cuánto tarda la instalación?</dt>
          <dd class="mt-1 text-xs sm:text-sm text-slate-400">
            Varía según el trabajo: un refuerzo de cerradura puede hacerse en una visita; una puerta nueva puede requerir medición y posterior instalación. Te lo concretamos al dar el presupuesto.
          </dd>
        </div>
      </dl>
    </section>

    <section class="rounded-xl border border-slate-800 bg-slate-900/40 p-4 text-sm text-slate-300">
      <h2 class="text-base font-semibold tracking-tight mb-2">
        Otros servicios de cerrajería
      </h2>
      <p>
        Además de puertas antiokupas, realizamos apertura de puertas, cambio e instalación de cerraduras y bombines, duplicado de llaves a domicilio y de coche, y arreglo de ventanas oscilobatientes. Si necesitas un cerrajero urgente 24 horas en {data.nombre}, tenemos página específica:{' '}
        <a href={`/cerrajero-urgente-24h/${entry.slug}`} class="text-emerald-400 hover:underline">cerrajero 24h en {data.nombre}</a>. Listado completo en{' '}
        <a href="/servicios" class="text-emerald-400 hover:underline">servicios de cerrajería</a>.
      </p>
    </section>

    {otrasZonas.length > 0 && (
      <section class="space-y-3">
        <h2 class="text-base font-semibold tracking-tight">
          Puertas antiokupas en otras zonas
        </h2>
        <ul class="grid gap-2 text-sm sm:grid-cols-2">
          {otrasZonas.map((other) => (
            <li>
              <a
                href={`${basePath}/${other.slug}`}
                class="text-slate-300 hover:text-emerald-400 hover:underline"
              >
                Puertas antiokupas en {other.data.nombre}
              </a>
            </li>
          ))}
        </ul>
        <p class="text-xs text-slate-400">
          <a href={basePath} class="text-emerald-400 hover:underline">Ver puertas antiokupas en Madrid →</a>
        </p>
      </section>
    )}

    <div class="flex flex-wrap items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/50 p-4">
      <p class="text-sm text-slate-300">
        ¿Necesitas presupuesto en {data.nombre}? Llámanos.
      </p>
      <a
        href={siteConfig.telefonoHref}
        class="inline-flex items-center justify-center rounded-full bg-emerald-500 px-5 py-2.5 text-sm font-semibold text-slate-950 transition hover:bg-emerald-400"
      >
        📞 {siteConfig.telefono}
      </a>
    </div>
  </article>
</Layout>
