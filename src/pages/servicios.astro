---
import Layout from '../components/Layout.astro';
import { siteConfig } from '../config/site';
import { servicios } from '../data/servicios';

const title = `Servicios de cerrajería 24h en ${siteConfig.ciudadPrincipal} | ${siteConfig.nombreComercial}`;
const description =
  'Listado de servicios de cerrajería urgente y no urgente: apertura de puertas y coches, cambio e instalación de cerraduras, duplicado de llaves a domicilio y de coche, arreglos de ventanas oscilobatientes y más en Madrid.';

const categorias = [
  { id: 'aperturas', nombre: 'Aperturas y urgencias' },
  { id: 'cerraduras', nombre: 'Cerraduras y bombines' },
  { id: 'llaves', nombre: 'Duplicado de llaves' },
  { id: 'ventanas', nombre: 'Ventanas y herrajes' },
  { id: 'otras', nombre: 'Otros trabajos de cerrajería' },
] as const;
---

<Layout {title} {description}>
  <section class="space-y-6">
    <h1 class="text-2xl font-extrabold tracking-tight sm:text-3xl">
      Servicios de cerrajería en {siteConfig.ciudadPrincipal}
    </h1>
    <p class="text-sm text-slate-300 sm:text-base">
      Estos son algunos de los servicios que ofrecemos a diario. Si tu problema no aparece en la lista, lo más
      probable es que también podamos ayudarte: llámanos y cuéntanos qué ha pasado.
    </p>
    <p class="text-xs text-slate-400 sm:text-sm">
      Trabajamos en toda la Comunidad de Madrid y podemos desplazarnos rápidamente a barrios como Getafe, Las Rozas,
      Pinto o Leganés. También atendemos otros distritos de Madrid ciudad; puedes consultar las zonas actuales en la
      página de{' '}
      <a href="/cerrajero-urgente-24h" class="text-emerald-400 hover:underline">
        barrios
      </a>
      .
    </p>

    {categorias.map((categoria) => (
      <section class="mt-4 space-y-3">
        <h2 class="text-base font-semibold tracking-tight">
          {categoria.nombre}
        </h2>
        <ul class="grid gap-3 sm:grid-cols-2">
          {servicios
            .filter((s) => s.categoria === categoria.id)
            .map((servicio) => {
              const enlaceServicio = servicio.slug === 'duplicado-llaves-coche' ? '/duplicado-llaves-coche' : null;
              return (
                <li class="rounded-xl border border-slate-800 bg-slate-900/70 p-4 text-sm">
                  {enlaceServicio ? (
                    <a href={enlaceServicio} class="block hover:border-slate-700">
                      <h3 class="font-semibold text-emerald-400 hover:underline">{servicio.nombre}</h3>
                      <p class="mt-1 text-xs text-slate-400">
                        {servicio.descripcionCorta}
                      </p>
                      <p class="mt-2 text-xs text-emerald-400/80">Ver zonas donde está disponible →</p>
                    </a>
                  ) : (
                    <>
                      <h3 class="font-semibold">{servicio.nombre}</h3>
                      <p class="mt-1 text-xs text-slate-400">
                        {servicio.descripcionCorta}
                      </p>
                    </>
                  )}
                </li>
              );
            })}
        </ul>
        {categoria.id === 'aperturas' && (
          <div class="mt-2 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60">
            <picture>
              <source srcset="/images/apertura-puerta-blindada.webp" type="image/webp" />
              <img
                src="/images/apertura-puerta-blindada.webp"
                alt="Detalle de apertura de cerradura blindada por un cerrajero profesional"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </picture>
          </div>
        )}
        {categoria.id === 'ventanas' && (
          <div class="mt-2 overflow-hidden rounded-2xl border border-slate-800 bg-slate-900/60">
            <picture>
              <source srcset="/images/arreglo-ventana-oscilobatiente.webp" type="image/webp" />
              <img
                src="/images/arreglo-ventana-oscilobatiente.webp"
                alt="Mano ajustando una ventana oscilobatiente de PVC en un piso de Madrid"
                class="h-full w-full object-cover"
                loading="lazy"
              />
            </picture>
          </div>
        )}
      </section>
    ))}
  </section>
</Layout>

